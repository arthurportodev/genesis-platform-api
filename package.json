{
  "name": "genesis-platform-api",
  "version": "0.1.0",
  "description": "Backend API for the Genesis Platform",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "start:invitation-worker": "node dist/invitation-worker.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand",
    "test:integration": "jest --config test/jest-integration.json --runInBand",
    "test:db:up": "docker compose -f compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f compose.test.yml down -v",
    "task:preflight": "node scripts/task-preflight.cjs",
    "task:fingerprint": "node scripts/task-fingerprint.cjs",
    "task:validate": "node scripts/task-validate.cjs",
    "format:check:task-tools": "prettier --check \"scripts/**/*.cjs\" \"test/task-tools/**/*.cjs\" \".codex/task-manifest.example.json\"",
    "test:task-tools": "node --test test/task-tools/*.test.cjs",
    "db:test:env": "node scripts/db-test-env.cjs",
    "gate2:validate": "node scripts/gate2-validate.cjs",
    "prepare:runtime": "node scripts/prepare-runtime.cjs",
    "migration:create": "typeorm migration:create",
    "migration:generate": "npm run prepare:runtime && node node_modules/typeorm/cli.js -d dist/database/data-source.js migration:generate",
    "migration:run": "npm run prepare:runtime && node node_modules/typeorm/cli.js -d dist/database/data-source.js migration:run",
    "migration:revert": "npm run prepare:runtime && node node_modules/typeorm/cli.js -d dist/database/data-source.js migration:revert",
    "migration:show": "npm run prepare:runtime && node node_modules/typeorm/cli.js -d dist/database/data-source.js migration:show",
    "seed": "npm run prepare:runtime && node dist/database/seeds/initial-tenant.seed.js",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/typeorm": "^11.0.3",
    "argon2": "^0.45.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "joi": "^18.2.3",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
