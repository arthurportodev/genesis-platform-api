NODE_ENV=development
PORT=3000
APP_NAME=Genesis Platform API
APP_VERSION=0.1.0

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=genesis_platform
DATABASE_USER=genesis_runtime
DATABASE_PASSWORD=change-runtime-password
# Deve ser exatamente a mesma role LOGIN usada em DATABASE_USER.
DATABASE_RUNTIME_ROLE=genesis_runtime
# Credenciais exclusivas do job/CLI de migrations e seed; não exponha à API.
DATABASE_MIGRATION_USER=genesis_owner
DATABASE_MIGRATION_PASSWORD=change-owner-password

FRONTEND_URL=http://localhost:5173
TRUST_PROXY_HOPS=0

TEST_DATABASE_HOST=localhost
TEST_DATABASE_PORT=5433
TEST_DATABASE_NAME=genesis_platform_test
TEST_DATABASE_USER=genesis_test
TEST_DATABASE_PASSWORD=test-only

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
REFRESH_TOKEN_PEPPER=replace-with-a-long-random-secret
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_IP_MAX_ATTEMPTS=25
AUTH_LOGIN_MAX_BUCKETS=10000
AUTH_LOGIN_WINDOW_SECONDS=900

# Convites 0.2.5.2: habilitação sempre explícita e fail-closed.
INVITATION_ISSUANCE_READINESS=false
INVITATION_ACCEPTANCE_READINESS=false
INVITATION_ACTIVATION_READINESS=false
INVITATION_ACCEPTANCE_URL=https://app.example.com/invitations/accept
INVITATION_EMAIL_FROM=Genesis <invitations@example.com>
INVITATION_TOKEN_CURRENT_VERSION=1
# JSON versionado; cada valor é base64 canônico de pelo menos 32 bytes.
INVITATION_TOKEN_KEYS={}
INVITATION_WORKER_ENABLED=false
INVITATION_WORKER_HEALTH_PORT=3001
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
INVITATION_RATE_LIMIT_WINDOW_SECONDS=900
INVITATION_INSPECT_IP_MAX_ATTEMPTS=30
INVITATION_ACCEPT_IP_MAX_ATTEMPTS=20
INVITATION_ACCEPT_USER_IP_MAX_ATTEMPTS=10
INVITATION_ACTIVATION_IP_MAX_ATTEMPTS=20
INVITATION_ACTIVATION_INVITATION_IP_MAX_ATTEMPTS=5
# Limites process-local: manter 1 rÃ©plica enquanto nÃ£o houver coordenaÃ§Ã£o compartilhada.
INVITATION_ACTIVATION_HASH_CONCURRENCY=2
INVITATION_PUBLIC_REPLICA_COUNT=1
INVITATION_RATE_LIMIT_MAX_BUCKETS=10000
